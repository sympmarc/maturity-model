{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "build": {
    "content": [
      {
        "files": [
          "**/*.md",
          "**/*.yml"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "docs/media/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "docs/templates/material"
    ],
    "globalMetadata": {
      "_appName": "Maturity Model for Microsoft 365",
      "_appTitle": "Maturity Model for Microsoft 365",
      "_enableSearch": true,
      "pdf": false,
      "_appFaviconPath": "docs/media/favicon.ico",
      "_enableNewTab": true
    }
  }
}